+void MainPicker::onScreenSelectionChanged() {
+    updateScreenPreviewLabel();
+
+    if (m_waylandCapture) {
+        auto items = ui->screenList->selectedItems();
+        if (!items.isEmpty()) {
+            QString outputName = m_screenMap[items[0]];
+            if (!outputName.isEmpty())
+                m_waylandCapture->startLiveOutputCapture(outputName);
+        } else {
+            m_waylandCapture->stopLiveOutputCapture();
+        }
+    }
+}
+
+void MainPicker::updateScreenPreview(const QString& outputName, const QImage& image) {
+    m_screenImages[outputName] = image;
+
+    auto items = ui->screenList->selectedItems();
+    if (items.isEmpty()) return;
+
+    if (m_screenMap[items[0]] == outputName) {
+        updateScreenPreviewLabel();
+    }
+}
+
+void MainPicker::updateScreenPreviewLabel() {
+    auto items = ui->screenList->selectedItems();
+    if (items.isEmpty()) {
+        ui->screenPreview->setText("Select a screen to preview");
+        return;
+    }
+
+    QString outputName = m_screenMap[items[0]];
+    if (m_screenImages.contains(outputName)) {
+        QPixmap pm = QPixmap::fromImage(m_screenImages[outputName]);
+        if (!pm.isNull()) {
+            QSize previewSize = ui->screenPreview->size();
+            qreal dpr = ui->screenPreview->devicePixelRatio();
+            QSize targetSize = previewSize * dpr;
+            if (targetSize.width() < 100 || targetSize.height() < 100) {
+                targetSize = QSize(640, 480) * dpr;
+            }
+            pm = pm.scaled(targetSize, Qt::KeepAspectRatio, Qt::SmoothTransformation);
+            pm.setDevicePixelRatio(dpr);
+            ui->screenPreview->setPixmap(pm);
+            return;
+        }
+    }
+    ui->screenPreview->setText("No preview available");
+}
+
 void MainPicker::resizeEvent(QResizeEvent* event) {
     QDialog::resizeEvent(event);
     updatePreviewLabel();
+    updateScreenPreviewLabel();
 }
 
 void MainPicker::showEvent(QShowEvent* event) {
     QDialog::showEvent(event);
     updatePreviewLabel();
+    updateScreenPreviewLabel();
 }
 
 void MainPicker::updatePreviewLabel() {
