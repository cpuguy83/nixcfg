+void WaylandCapture::captureOutput(const QString& outputName) {
+    if (!m_screencopyManager || !m_shm) return;
+    if (!m_outputs.contains(outputName)) return;
+
+    if (m_outputSessions.contains(outputName)) {
+        m_outputSessions.remove(outputName);
+    }
+
+    auto output = m_outputs[outputName];
+    auto frame = makeShared<CCZwlrScreencopyFrameV1>(m_screencopyManager->sendCaptureOutput(0, output->resource()));
+    auto session = std::make_shared<OutputCaptureSession>();
+    session->frame = frame;
+    m_outputSessions[outputName] = session;
+
+    frame->setBuffer([this, outputName](CCZwlrScreencopyFrameV1* r, uint32_t format, uint32_t width, uint32_t height, uint32_t stride) {
+        if (!m_outputSessions.contains(outputName)) return;
+        auto& s = m_outputSessions[outputName];
+        if (s->size > 0) return;
+        s->width = width;
+        s->height = height;
+        s->stride = stride;
+        s->format = format;
+        s->size = stride * height;
+    });
+
+    frame->setBufferDone([this, outputName](CCZwlrScreencopyFrameV1* r) {
+        if (!m_outputSessions.contains(outputName)) return;
+        auto& s = m_outputSessions[outputName];
+
+        if (s->size <= 0) return;
+
+        int fd = create_shm_file(s->size);
+        if (fd < 0) return;
+
+        s->data = mmap(NULL, s->size, PROT_READ | PROT_WRITE, MAP_SHARED, fd, 0);
+        if (s->data == MAP_FAILED) {
+            close(fd);
+            return;
+        }
+
+        auto pool = makeShared<CCWlShmPool>(m_shm->sendCreatePool(fd, s->size));
+        s->buffer = makeShared<CCWlBuffer>(pool->sendCreateBuffer(0, s->width, s->height, s->stride, s->format));
+
+        pool->sendDestroy();
+        pool.reset();
+
+        r->sendCopy(s->buffer->resource());
+        close(fd);
+        wl_display_flush(m_display);
+    });
+
+    frame->setFlags([this, outputName](CCZwlrScreencopyFrameV1* r, uint32_t flags) {
+        if (!m_outputSessions.contains(outputName)) return;
+        m_outputSessions[outputName]->yInvert = (flags & 1) != 0;
+    });
+
+    frame->setReady([this, outputName](CCZwlrScreencopyFrameV1* r, uint32_t tv_sec_hi, uint32_t tv_sec_lo, uint32_t tv_nsec) {
+        if (!m_outputSessions.contains(outputName)) return;
+        auto s = m_outputSessions[outputName];
+
+        QImage::Format fmt = QImage::Format_ARGB32;
+        if (s->format == WL_SHM_FORMAT_XRGB8888)
+            fmt = QImage::Format_RGB32;
+        else if (s->format == WL_SHM_FORMAT_ARGB8888)
+            fmt = QImage::Format_ARGB32_Premultiplied;
+
+        QImage img((uchar*)s->data, s->width, s->height, s->stride, fmt);
+        QImage copy = img.copy();
+
+        if (s->yInvert)
+            copy = copy.mirrored(false, true);
+
+        r->sendDestroy();
+
+        emit outputFrameCaptured(outputName, copy);
+
+        if (m_liveOutputActive && outputName == m_liveOutputName) {
+            QTimer::singleShot(m_liveOutputIntervalMs, this, [this]() {
+                if (m_liveOutputActive)
+                    captureOutput(m_liveOutputName);
+            });
+        }
+
+        QTimer::singleShot(0, this, [this, outputName]() {
+            m_outputSessions.remove(outputName);
+        });
+    });
+
+    frame->setFailed([this, outputName](CCZwlrScreencopyFrameV1* r) {
+        if (m_outputSessions.contains(outputName)) {
+            m_outputSessions[outputName]->frame->sendDestroy();
+            QTimer::singleShot(0, this, [this, outputName]() {
+                m_outputSessions.remove(outputName);
+            });
+        }
+    });
+
+    wl_display_flush(m_display);
+}
+
+void WaylandCapture::startLiveOutputCapture(const QString& outputName, int intervalMs) {
+    m_liveOutputActive = false;
+    m_liveOutputName = outputName;
+    m_liveOutputIntervalMs = intervalMs;
+    m_liveOutputActive = true;
+    captureOutput(outputName);
+}
+
+void WaylandCapture::stopLiveOutputCapture() {
+    m_liveOutputActive = false;
+}
